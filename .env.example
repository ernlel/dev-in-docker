# ──────────────────────────────────────────────────────────────────────
#  Dev Environment — configuration overrides
# ──────────────────────────────────────────────────────────────────────
#  Copy to .env and adjust before `docker compose up`:
#    cp .env.example .env
#    docker compose up -d
# ──────────────────────────────────────────────────────────────────────

# ── Build-time versions (require `docker compose build --no-cache`) ──
NODE_VERSION=24
AIONUI_REPO=https://github.com/iOfficeAI/AionUi.git
AIONUI_TAG=v2.1.18
AIONCORE_VERSION=v0.1.30
CODE_SERVER_VERSION=4.123.0

# ── Runtime ──

# Host path to mount as the dev home inside container.
HOST_HOME=/path/to/your/dev/dir

# Mount target (must match DEV_HOME in entrypoint).
CONTAINER_HOME=/home/dev

# code-server
CODE_SERVER_PORT=7701
CODE_SERVER_PASSWORD=change-me

# AionUI Web
AIONUI_ENABLED=true
AIONUI_PORT=7700
AIONUI_PASSWORD=change-me

# AionUI CLI agents to install at runtime (comma-separated, set before `up`).
# Marked ✗ below are NOT auto-detected by AionUI but remain CLI-usable.
# Supported: claude, codex, copilot, opencode, goose, gemini, qwen,
#            augment, codebuddy, kimi, factory, qoder, mistral-vibe,
#            snow, hermes, cursor-agent, kiro, openclaw, nanobot, iflow
# Not supported by AionUI: pi, kilo, grok
AIONUI_CLI_AGENTS=copilot,opencode,pi,kilo,gemini,goose,qwen,codebuddy,kimi,kiro

# mise default tools (space-separated: tool@version)
MISE_DEFAULT_TOOLS=nodejs@26 python@3 rust@latest go@1.26

# UID/GID fallback
DEV_UID=1000
DEV_GID=1000
