# ──────────────────────────────────────────────────────────────────────
#  Dev Environment — configuration overrides
# ──────────────────────────────────────────────────────────────────────
#  Copy to .env and adjust before `docker compose up`:
#    cp .env.example .env
#    docker compose up -d
# ──────────────────────────────────────────────────────────────────────

# ── Build-time versions (require `docker compose build --no-cache`) ──
# Defaults to "latest" — set specific versions to pin.
NIX_VERSION=latest
CODE_SERVER_VERSION=latest
OPENCODE_VERSION=latest

# ── Runtime ──

# Host path to mount as the dev home inside container.
HOME_MOUNT=/path/to/your/dev/dir

# Host path to mount as /workspace (uncomment to enable):
# WORKSPACE_MOUNT=/path/to/project

# code-server
CODE_SERVER_PORT=8443
CODE_SERVER_PASSWORD=change-me

# opencode web server
OPENCODE_PORT=3000
OPENCODE_USERNAME=opencode
OPENCODE_PASSWORD=change-me

# mise default tools (space-separated: tool@version)
MISE_DEFAULT_TOOLS=nodejs@latest python@latest rust@latest go@latest

# UID/GID fallback
DEV_UID=1000
DEV_GID=1000

# ── Extra volume mounts ──
# Create docker-compose.override.yml next to docker-compose.yml:
#
#   services:
#     dev:
#       volumes:
#         - "${HOME_MOUNT:-~}:/home/dev:consistent,z"
#         - /var/run/docker.sock:/var/run/docker.sock
#         - ./post-install.sh:/app/post-install.sh:ro
#         # ^ copy default volumes above, then add yours below:
#         - /host/path:/container/path
#         - /another/path:/another:ro
